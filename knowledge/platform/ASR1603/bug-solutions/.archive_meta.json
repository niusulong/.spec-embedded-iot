      "summary": {
        "platform": "ASR1603",
        "module": "FTP / AT框架",
        "bug_type": "异步回调端口错乱",
        "symptoms": [
          "URC端口切换",
          "FILEFTPGET进度上报",
          "USB端口抢占"
        ],
        "root_cause": "全局变量 `nwy_at_engine` 在每次AT命令处理时被覆写，FTP异步回调通过该全局变量获取端口，导致后续AT命令所在端口覆盖原始发起端口",
        "call_chain_summary": "`AT_NWY_CmdFunc_Adpt()` → `nwy_at_engine = *xid_p` → FTP回调 → `nwy_app_at_get_plat_at_channel()` → `&nwy_at_engine` → `nwy_buf_echo_port()`",
        "keywords": [
          "nwy_at_engine",
          "FILEFTPGET",
          "URC",
          "端口切换",
          "at_channel",
          "异步回调"
        ]
      }
    },
    "FILEFTPGET下载进度URC端口错乱": {
      "title": "FILEFTPGET下载进度URC端口错乱",
      "file": "FILEFTPGET下载进度URC端口错乱.md",
      "hash": "a7dbe06150034148021f39210e91872e",
      "archived_at": "2026-06-12T16:03:02.583361",
      "source_files": [
        "FILEFTPGET下载进度URC端口错乱分析报告.md"
      ],
      "summary": {
        "platform": "ASR1603",
        "module": "FTP / AT框架",
        "bug_type": "异步回调端口错乱",
        "symptoms": [
          "URC端口错乱",
          "FILEFTPGET进度上报",
          "全局变量覆盖"
        ],
        "root_cause": "`nwy_at_engine` 是全局单一变量，每次AT命令到来时被覆盖写入，异步回调中通过该变量获取端口信息时取到最新命令端口而非原始命令端口",
        "call_chain_summary": "`AT_NWY_CmdFunc_Adpt()` → `nwy_at_engine = *xid_p` → `nwy_ftp_rsp_cb()` → `nwy_app_at_get_plat_at_channel()` → `nwy_app_at_unsol_str()` → `nwy_buf_echo_port()`",
        "keywords": [
          "nwy_at_engine",
          "FILEFTPGET",
          "URC",
          "at_channel",
          "nwy_app_at_get_plat_at_channel",
          "全局变量"
        ]
      }
    },
    "FILEFTPGET文件写入失败": {
