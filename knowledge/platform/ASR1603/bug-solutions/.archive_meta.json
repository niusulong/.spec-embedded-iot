    "NA_rti_switchout_null_deref": {
      "title": "NA_rti_switchout_null_deref",
      "work_item_id": "NA",
      "file": "ASR1603_NA_rti_switchout_null_deref.md",
      "hash": "e7171f8f478f84e41c6c68e6429a9021",
      "archived_at": "2026-06-16T20:08:13.922551",
      "source_files": [
        "Dump分析.md"
      ],
      "summary": {
        "work_item_id": "NA",
        "platform": "ASR1603",
        "module": "TCP自动重建(nwy_tcpsrv_redial) / PPPREDIAL / RTI线程切换插桩",
        "bug_type": "任务栈溢出→内存破坏→空指针解引用(DataAbort)，已修复",
        "symptoms": [
          "DataAbort",
          "rti_thread_switch_out",
          "空指针解引用",
          "RTI记录全零",
          "FAULT_ADDRESS=0xE59FF018",
          "栈溢出",
          "越界写",
          "任务栈2048B",
          "nwy_tcpsrv_redial",
          "cisend"
        ],
        "root_cause": "新增的 TCP 自动重建任务 `nwy_tcpsrv_redial` 栈仅 2048B，在 ASR(Cortex-R+ThreadX+ASR TCP栈) 上执行 `nwy_app_tcp_server_setup/_v6` 深 TCP 建链调用时栈溢出，越界清零相邻堆内存中的 RTI per-thread 记录；当 nwy_cp_service 任务被上下文切换切出时，`rti_thread_switch_out` 读取该全零记录 → NULL 解引用读向量表得 0xE59FF018 → 再解引用未映射地址 → DataAbort 死机。栈改 8192 后实测不再死机。",
        "call_chain_summary": "`AT+CFUN=0/1` 断网恢复 → data_cb → redial 任务 `nwy_yddl_tcpsrv_redial_server_func`(2048B栈) → `nwy_app_tcp_server_setup/_v6`(深栈,溢出) → 越界清零 RTI 记录 → 切出 nwy_cp_service → `switch_out` → `rti_thread_switch_out` 读 record[0]=0 → *(0xC)=0xE59FF018 → *(0xE59FF018) → DataAbort",
        "keywords": [
          "DataAbort",
          "rti_thread_switch_out",
          "switch_out",
          "RTI记录全零",
          "0xE59FF018",
          "nwy_tcpsrv_redial",
          "栈溢出",
          "任务栈大小",
          "NWY_TCPSRV_REDIAL_TASK_STACK_SIZE",
          "跨平台移植栈大小",
          "UIS8852到ASR",
          "PPPREDIAL",
          "TCPLISTEN",
          "nwy_cp_service",
          "ciRequest",
          "nwy_app_tcp_server_setup",
          "空指针解引用",
          "越界写堆"
        ]
      }
    },
    "7018786802_UDP_V6源地址上报错误": {
      "title": "UDP_V6源地址上报错误",
      "work_item_id": "7018786802",
      "file": "ASR1603_UDP_V6源地址上报错误.md",
      "hash": "8b750e53b5a1f7ec3f12111b37a2847a",
      "archived_at": "2026-06-17T16:50:18.644164",
      "source_files": [
        "报告.md"
      ],
      "summary": {
        "work_item_id": "7018786802",
        "platform": "ASR1603",
        "module": "AT 命令 / UDP 服务端 / IPv6 地址处理",
        "bug_type": "IPv6 地址格式化类型转换错误",
        "symptoms": [
          "UDPSENDS ERROR、UDPRECV(S) 源 IP 错误、IPv6 地址截断、V6 链路收不到数据"
        ],
        "root_cause": "UDP 服务端 `+UDPRECV(S)` URC 生成时，`nwy_app_ip6addr_ntoa()` 入参类型不匹配，将 `struct nwy_ps_in6_addr*` 直接强转 `void*` 当作 `nwy_ip_addr_type*` 使用，内部按 `addr->addr.v6`（偏移 type 字段后的 uint64[2]）读取，导致取到的 IPv6 地址只有后半段（4组），前半段丢失，生成的 URC 报告了错误且不完整的源 IPv6 地址",
        "call_chain_summary": "`nwy_app_at_udp_server_cb` → `nwy_app_ip6addr_ntoa(&addr_v6->ps_sin6_addr)` ← 类型不匹配",
        "keywords": [
          "UDPSENDS ERROR",
          "UDPRECV",
          "IPv6 地址错误",
          "ip6addr_ntoa",
          "nwy_app_ip6addr_ntoa"
        ]
      }
    }
