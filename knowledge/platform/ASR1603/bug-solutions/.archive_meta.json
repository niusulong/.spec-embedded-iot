      "summary": {
        "platform": "ASR1603",
        "module": "FTP / LFS文件系统",
        "bug_type": "存储空间不足",
        "symptoms": [
          "File Write Fail",
          "LFS No more free space",
          "FTP下载失败"
        ],
        "root_cause": "Flash文件系统(LFS)存储空间耗尽，`nwy_vfs_fwrite` 返回0，触发 `+FILEFTPGET: File Write Fail` 错误上报并中止FTP传输",
        "call_chain_summary": "`nwy_app_at_fileftpget_func()` → `nwy_ftp_rsp_cb()` → `nwy_ftp_file_write()` → `nwy_vfs_fwrite()` → LFS: No more free space",
        "keywords": [
          "FILEFTPGET",
          "File Write Fail",
          "LFS",
          "No more free space",
          "nwy_vfs_fwrite",
          "Flash空间"
        ]
      }
    },
